{
  "Cors": {
    "AllowedOrigins": [
      "https://www.garge.no",
      "https://garge.no",
      "https://dev.garge.no",
      "http://localhost:3000",
      "http://localhost:3001"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "None"
    },
    "Console": {
      "IncludeScopes": true,
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff ",
        "IncludeScopes": true
      }
    }
  },
  "Storage": {
    "ReportsPath": "./_storage/reports",
    "MaxReportBytes": 52428800
  }
}
