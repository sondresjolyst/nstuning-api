{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "None"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "https://nstuning.no",
    "Key": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "https://nstuning.no",
      "https://www.nstuning.no",
      "https://dev.nstuning.no"
    ]
  },
  "BrevoSettings": {
    "ApiKey": "",
    "SenderEmail": "noreply@nstuning.no",
    "SenderName": "NS Tuning"
  },
  "Storage": {
    "ReportsPath": "/data/reports",
    "MaxReportBytes": 52428800
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "*:/api/auth/login", "Period": "1m", "Limit": 10 },
      { "Endpoint": "*:/api/auth/register", "Period": "1m", "Limit": 5 },
      { "Endpoint": "*:/api/auth/refresh-token", "Period": "1m", "Limit": 20 },
      { "Endpoint": "*:/api/contact", "Period": "1m", "Limit": 5 }
    ]
  }
}
